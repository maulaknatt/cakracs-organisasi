{
    "version": 2,
    "outputDirectory": "public",
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/favicon\\.(ico|png|svg|webp)",
            "dest": "/public/$0"
        },
        {
            "src": "/robots\\.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/monyet\\.png",
            "dest": "/public/monyet.png"
        },
        {
            "src": "/(css|js|images|sounds|fonts|build|storage)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/.*\\.(png|jpg|jpeg|gif|svg|ico|webp|mp3|wav|woff|woff2|ttf|eot)",
            "dest": "/public/$0"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_STORE": "array",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "APP_MAINTENANCE_STORE": "array",
        "DB_CONNECTION": "pgsql",
        "DB_HOST": "aws-1-ap-southeast-2.pooler.supabase.com",
        "DB_PORT": "5432",
        "DB_USERNAME": "postgres.avzgbcszjpojelmrgnbw"
    }
}